<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Material 3 theme -->
    <style name="Theme.Gemosto" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/emerald_primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/emerald_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/background_default</item>
        <item name="android:windowBackground">@color/background_default</item>
    </style>

    <!-- Splash theme (Android 12+ SplashScreen API) -->
    <style name="Theme.Gemosto.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/emerald_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Gemosto</item>
    </style>

</resources>
